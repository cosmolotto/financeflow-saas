# FinanceFlow SaaS — Environment Variables
# Copy this to .env and fill in your values.
# All values are required for full functionality unless marked OPTIONAL.

# ── Core ────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-64-char-string
APP_URL=https://your-app.up.railway.app

# ── Database ────────────────────────────────────────────────────────────
# Leave empty to use SQLite (local dev). Set for production PostgreSQL.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Google / YouTube OAuth ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── OpenAI (script generation) ──────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── ElevenLabs (AI voice) — OPTIONAL ────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Stripe (payments) — OPTIONAL ────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email / Brevo — OPTIONAL ────────────────────────────────────────────
BREVO_API_KEY=

# ── Redis / Celery (fast queue) — OPTIONAL ──────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Admin access key (REQUIRED — set to a strong random string) ─────────
# Without this set, the /api/admin/create endpoint is disabled.
MASTER_ADMIN_KEY=change-this-to-a-strong-random-key

# ── CORS ────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * for all (dev only).
ALLOWED_ORIGINS=https://your-app.up.railway.app

# ── System Twitter channel (OPTIONAL) ───────────────────────────────────
SYSTEM_TWITTER_API_KEY=
SYSTEM_TWITTER_API_SECRET=
SYSTEM_TWITTER_ACCESS_TOKEN=
SYSTEM_TWITTER_ACCESS_SECRET=
